<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fabrika Sıra Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body { background: #f5f7fb; }
        .navbar { box-shadow: 0 10px 30px rgba(15, 23, 42, .08); }
        .content-shell { max-width: 1320px; margin: 0 auto; padding: 28px 20px; }
        .card { border: 0; border-radius: 20px; box-shadow: 0 18px 45px rgba(15, 23, 42, .08); }
        .table { margin-bottom: 0; }
        .table th { color: #64748b; font-size: .78rem; text-transform: uppercase; letter-spacing: .04em; }
        .table td { vertical-align: middle; }
        .table-hover tbody tr:hover { background: #f8fafc; }
        .btn { border-radius: 12px; font-weight: 700; }
        .form-control { border-radius: 12px; }
        .badge { border-radius: 999px; padding: .55rem .75rem; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg bg-white sticky-top">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold text-primary" href="/Admin/Dashboard">Fabrika Sıra Admin</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="adminNav">
                <div class="navbar-nav ms-auto gap-lg-2">
                    <a class="nav-link" href="/Admin/Dashboard">Dashboard</a>
                    <a class="nav-link" href="/Admin/Queue">Sıra</a>
                    <a class="nav-link" href="/Admin/Shipments">Sevkiyatlar</a>
                    <a class="nav-link" href="/Admin/Shipments/Completed">Tamamlananlar</a>
                    <a class="nav-link" href="/Admin/Users">Kullanıcılar</a>
                    <a class="nav-link" href="/Admin/Vehicles">Araçlar</a>
                </div>
            </div>
        </div>
    </nav>
    <main class="content-shell">@RenderBody()</main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
