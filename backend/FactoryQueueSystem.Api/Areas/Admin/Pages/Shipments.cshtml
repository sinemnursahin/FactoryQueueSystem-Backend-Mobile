@page
@model FactoryQueueSystem.Api.Areas.Admin.Pages.ShipmentsModel
@functions {
    private static string StatusClass(int status) => status switch
    {
        1 => "text-bg-primary",
        2 => "text-bg-info",
        3 => "text-bg-warning",
        4 => "text-bg-warning",
        5 => "text-bg-secondary",
        6 => "text-bg-success",
        _ => "text-bg-secondary"
    };
}
<div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-center mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">Aktif Sevkiyatlar</h1>
        <p class="text-secondary mb-0">Kantar, tartım ve boşaltım sürecindeki araçlar.</p>
    </div>
</div>
@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success rounded-4">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger rounded-4">@Model.ErrorMessage</div>
}
<div class="card">
    <div class="card-body p-0">
        @if (Model.Items.Count == 0)
        {
            <div class="text-center p-5">
                <div class="display-6 text-secondary mb-2">✓</div>
                <h2 class="h5">Aktif sevkiyat yok</h2>
                <p class="text-secondary mb-0">Süreçteki sevkiyatlar burada listelenir.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Sıra</th>
                            <th>Plaka</th>
                            <th>Şoför</th>
                            <th>Malzeme</th>
                            <th>Durum</th>
                            <th>Dolu</th>
                            <th>Boş</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@(item.QueueNumber?.ToString() ?? "-")</td>
                            <td class="fw-bold">@item.PlateNumber</td>
                            <td>@item.DriverName</td>
                            <td>@item.RawMaterialName</td>
                            <td><span class="badge @StatusClass(item.Status)">@item.StatusName</span></td>
                            <td>@(item.LoadedWeight?.ToString("N2") ?? "-")</td>
                            <td>@(item.EmptyWeight?.ToString("N2") ?? "-")</td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    @if (item.Status == 1)
                                    {
                                        <form method="post" asp-page-handler="CallToScale" asp-route-id="@item.ShipmentId" onsubmit="return confirm('Araç kantara çağrılsın mı?');">
                                            <button class="btn btn-primary" type="submit">Kantara Çağır</button>
                                        </form>
                                    }
                                    @if (item.Status == 2)
                                    {
                                        <form class="d-flex gap-2 flex-wrap" method="post" asp-page-handler="LoadedWeight" asp-route-id="@item.ShipmentId" onsubmit="return confirm('Dolu tartım kaydedilsin mi?');">
                                            <input class="form-control" style="max-width: 150px" name="weight" type="number" step="0.01" min="0.01" placeholder="Dolu tartım" />
                                            <button class="btn btn-success" type="submit">Kaydet</button>
                                        </form>
                                    }
                                    @if (item.Status == 3)
                                    {
                                        <form method="post" asp-page-handler="StartUnloading" asp-route-id="@item.ShipmentId" onsubmit="return confirm('Boşaltım başlatılsın mı?');">
                                            <button class="btn btn-warning" type="submit">Boşaltımı Başlat</button>
                                        </form>
                                    }
                                    @if (item.Status == 4)
                                    {
                                        <form method="post" asp-page-handler="CompleteUnloading" asp-route-id="@item.ShipmentId" onsubmit="return confirm('Boşaltım tamamlansın mı?');">
                                            <button class="btn btn-secondary" type="submit">Tamamla</button>
                                        </form>
                                    }
                                    @if (item.Status == 5)
                                    {
                                        <form class="d-flex gap-2 flex-wrap" method="post" asp-page-handler="EmptyWeight" asp-route-id="@item.ShipmentId" onsubmit="return confirm('Boş tartım kaydedilip işlem tamamlansın mı?');">
                                            <input class="form-control" style="max-width: 150px" name="weight" type="number" step="0.01" min="0" placeholder="Boş tartım" />
                                            <button class="btn btn-success" type="submit">Bitir</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
