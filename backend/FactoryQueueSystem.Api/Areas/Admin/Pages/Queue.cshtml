@page
@model FactoryQueueSystem.Api.Areas.Admin.Pages.QueueModel
@functions {
    private static string StatusClass(int status) => status switch
    {
        1 => "text-bg-primary",
        2 => "text-bg-info",
        3 => "text-bg-warning",
        4 => "text-bg-warning",
        5 => "text-bg-secondary",
        6 => "text-bg-success",
        _ => "text-bg-secondary"
    };
}
<div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-center mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">Sıradaki Araçlar</h1>
        <p class="text-secondary mb-0">Tesise gelen ve kantar çağrısı bekleyen araçlar.</p>
    </div>
</div>
@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success rounded-4">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger rounded-4">@Model.ErrorMessage</div>
}
<div class="card">
    <div class="card-body p-0">
        @if (Model.Items.Count == 0)
        {
            <div class="text-center p-5">
                <div class="display-6 text-secondary mb-2">⌁</div>
                <h2 class="h5">Sırada araç yok</h2>
                <p class="text-secondary mb-0">Yeni araçlar sıra aldığında burada görünür.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Sıra</th>
                            <th>Plaka</th>
                            <th>Şoför</th>
                            <th>Malzeme</th>
                            <th>Tedarikçi</th>
                            <th>Durum</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-bold">@item.QueueNumber</td>
                            <td class="fw-bold">@item.PlateNumber</td>
                            <td>@item.DriverName</td>
                            <td>@item.RawMaterialName</td>
                            <td>@item.SupplierName</td>
                            <td><span class="badge @StatusClass(item.Status)">@item.StatusName</span></td>
                            <td>
                                <form method="post" asp-page-handler="CallToScale" asp-route-id="@item.ShipmentId" onsubmit="return confirm('Araç kantara çağrılsın mı?');">
                                    <button class="btn btn-primary btn-lg" type="submit">Kantara Çağır</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
